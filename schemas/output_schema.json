{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ohbryt/arp-v24/schemas/output_schema.json",
  "title": "ARP Pipeline Output Schema",
  "description": "Standard output schema for ARP pipeline results",
  "type": "object",
  "required": ["disease", "targets", "candidates", "evidence", "meta", "next_actions"],
  "properties": {
    "disease": {
      "type": "string",
      "description": "Target disease indication"
    },
    "date": {
      "type": "string",
      "description": "Report generation date (ISO 8601)"
    },
    "targets": {
      "type": "array",
      "description": "List of validated targets",
      "items": {
        "type": "object",
        "required": ["name", "rationale", "confidence", "evidence_level"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Target gene/protein name"
          },
          "mechanism": {
            "type": "string",
            "description": "Mechanism of action"
          },
          "rationale": {
            "type": "string",
            "description": "Scientific rationale"
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"],
            "description": "Confidence level"
          },
          "evidence_level": {
            "type": "string",
            "enum": ["real", "validated", "heuristic", "simulated"],
            "description": "Evidence quality tier"
          },
          "evidence_label": {
            "type": "string",
            "description": "Human-readable evidence label"
          },
          "confidence_source": {
            "type": "string",
            "description": "What generated this result"
          },
          "validated_by": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Supporting PMIDs, papers, trials"
          }
        }
      }
    },
    "candidates": {
      "type": "array",
      "description": "List of compound candidates",
      "items": {
        "type": "object",
        "required": ["name", "target", "priority", "evidence_level"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Compound identifier"
          },
          "smiles": {
            "type": "string",
            "description": "SMILES structure"
          },
          "target": {
            "type": "string",
            "description": "Primary target"
          },
          "priority": {
            "type": "string",
            "enum": ["high", "medium", "low"],
            "description": "Development priority"
          },
          "ic50_nM": {
            "type": "number",
            "description": "Potency in nanomolar"
          },
          "evidence_level": {
            "type": "string",
            "enum": ["real", "validated", "heuristic", "simulated"]
          },
          "admet_notes": {
            "type": "string",
            "description": "ADMET considerations"
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "description": "Supporting evidence references",
      "properties": {
        "literature": {
          "type": "array",
          "items": {"type": "string"},
          "description": "PMID or paper references"
        },
        "clinical_trials": {
          "type": "array",
          "items": {"type": "string"},
          "description": "NCT trial identifiers"
        },
        "patents": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Patent numbers"
        }
      }
    },
    "meta": {
      "type": "object",
      "required": ["timestamp", "version", "branch"],
      "description": "Pipeline metadata",
      "properties": {
        "timestamp": {
          "type": "string",
          "description": "ISO 8601 timestamp"
        },
        "version": {
          "type": "string",
          "description": "Pipeline version"
        },
        "branch": {
          "type": "string",
          "description": "Git branch"
        },
        "commit_hash": {
          "type": "string",
          "description": "Git commit hash"
        },
        "tools_used": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Tools/AI models used"
        },
        "playbook": {
          "type": "string",
          "description": "Playbook used"
        }
      }
    },
    "next_actions": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Recommended next steps"
    },
    "evidence_summary": {
      "type": "object",
      "description": "Counts of evidence levels",
      "properties": {
        "real": {"type": "integer"},
        "validated": {"type": "integer"},
        "heuristic": {"type": "integer"},
        "simulated": {"type": "integer"}
      }
    }
  }
}